<html>
<head>
<HTA:APPLICATION
    ID="AphadayApp"
    APPLICATIONNAME="Aphaday"
    VERSION="2.0.1"
    BORDERSTYLE="normal"
    CAPTION="yes"
    CONTEXTMENU="yes"
    ICON="data:image/x-icon;base64,"
    SCROLL="yes"
    SCROLLFLAT="yes"
    SINGLEINSTANCE="yes"
    WINDOWSTATE="normal"
    WIDTH="1200"
    HEIGHT="800"
>
</HTA:APPLICATION>
</head>
<body scroll="no" style="margin:0;padding:0;overflow:hidden;background:#0e0e0d;">
<iframe id="app-frame" src="index.html" style="width:100%;height:100%;border:none;margin:0;padding:0;"></iframe>

<script>
// Maximizar janela quando abrir
try {
    var objShell = new ActiveXObject('Shell.Application');
    objShell.MinimizeAll();
    objShell = null;
} catch(e) {}

// Garantir que abre em fullscreen se desejar
function maximizeWindow() {
    try {
        window.resizeTo(screen.width, screen.height);
        window.moveTo(0, 0);
    } catch(e) {}
}

window.onload = function() {
    maximizeWindow();
};
</script>
</body>
</html>
